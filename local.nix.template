  # networking.hostName = "optiplex1";

  # Example: hardware-specific kernel modules
  # boot.initrd.kernelModules = [ "i915" ];

  # Admin user password hash — generate with: mkpasswd -m sha-512
  # users.users.admin.initialHashedPassword = "$6$...";
}
