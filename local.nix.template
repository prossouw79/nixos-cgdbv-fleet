# Copy this file to /persist/etc/nixos/local.nix on each device.
# This file must NEVER be committed to git.
#
# WiFi networks are now managed fleet-wide via agenix (secrets/wifi-credentials.age)
# and networking.networkmanager.ensureProfiles in modules/base.nix.
# You no longer need to configure WiFi here.
#
# Use this file only for per-device overrides that cannot go in the shared
# module, e.g. hardware-specific kernel modules or a custom hostname.
{ ... }:

{
